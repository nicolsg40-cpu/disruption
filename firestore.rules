rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: sessions
    // Document ID: auto-generated
    // Fields:
    //   - status: string (waiting, selecting_shock, playing, revealing, finished)
    //   - shockId: number (optional)
    //   - players: map (uid -> { roleId, choice, name, isReady })
    //   - score: number (optional)
    //   - createdAt: timestamp
    //
    // ===============================================================

    // Helper Functions
    function isValidSession(data) {
      return data.status in ['waiting', 'selecting_shock', 'playing', 'revealing', 'finished'] &&
             data.players is map &&
             data.createdAt is timestamp;
    }

    match /sessions/{sessionId} {
      // Allow public access to sessions (using the ID as the secret)
      allow read, create, update: if true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
