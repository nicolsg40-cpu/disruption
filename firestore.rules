rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: interactions
    // Document ID: auto-generated
    // Fields:
    //   - disruptionId: number (required)
    //   - roleId: number (required)
    //   - impactId: string (required)
    //   - restrictionId: string (required)
    //   - actionText: string (required, max 1000 chars)
    //   - timestamp: timestamp (required)
    //   - userId: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidInteraction(data) {
      return data.disruptionId is number &&
             data.roleId is number &&
             data.impactId is string &&
             data.restrictionId is string &&
             data.actionText is string && data.actionText.size() <= 1000 &&
             data.timestamp is timestamp;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "nicolsg40@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /interactions/{interactionId} {
      // Anyone can create an interaction (to allow anonymous participation)
      // But we validate the data strictly
      allow create: if isValidInteraction(request.resource.data);
      
      // Only admins can read the full list of interactions
      allow read: if isAdmin();
      
      // No updates or deletes allowed for now to preserve integrity
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
