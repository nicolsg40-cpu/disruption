rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: sessions
    // Document ID: auto-generated
    // Fields:
    //   - status: string (waiting, selecting_shock, playing, revealing, finished)
    //   - shockId: number (optional)
    //   - players: map (uid -> { roleId, choice, name, isReady })
    //   - score: number (optional)
    //   - createdAt: timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isPlayerInSession(sessionId) {
      return isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/sessions/$(sessionId)).data.players);
    }

    function isValidSession(data) {
      return data.status in ['waiting', 'selecting_shock', 'playing', 'revealing', 'finished'] &&
             data.players is map &&
             data.createdAt is timestamp;
    }

    match /sessions/{sessionId} {
      // Allow any authenticated user to read sessions (to join)
      allow read: if isAuthenticated();
      
      // Allow creation of a new session
      allow create: if isAuthenticated() && 
                    isValidSession(request.resource.data) &&
                    request.resource.data.players.keys().size() == 1 &&
                    request.resource.data.players.keys().hasAll([request.auth.uid]);

      // Allow updates if the user is a player in the session
      // For simplicity in this prototype, we allow the update if they are a player
      // and the session structure remains valid.
      allow update: if isAuthenticated() && 
                    isValidSession(request.resource.data) &&
                    (request.auth.uid in resource.data.players || request.resource.data.players.keys().size() <= 3);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
